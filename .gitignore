# ─────────────────────────────────────────
# Python
# ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc

# ─────────────────────────────────────────
# Virtual Environment
# ─────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.bak

# ─────────────────────────────────────────
# Environment Variables
# ─────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
!.env.example        # always keep the example file

# ─────────────────────────────────────────
# FastAPI / Uvicorn
# ─────────────────────────────────────────
*.log
logs/

# ─────────────────────────────────────────
# Alembic
# ─────────────────────────────────────────
# Keep migrations folder but ignore cache
migrations/__pycache__/

# ─────────────────────────────────────────
# Docker
# ─────────────────────────────────────────
.docker/

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─────────────────────────────────────────
# Testing
# ─────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ─────────────────────────────────────────
# VS Code
# ─────────────────────────────────────────
.vscode/
!.vscode/extensions.json   # share recommended extensions

# ─────────────────────────────────────────
# JetBrains (PyCharm etc.)
# ─────────────────────────────────────────
.idea/
*.iml

# ─────────────────────────────────────────
# OS
# ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────
# Uploads / Media
# ─────────────────────────────────────────
uploads/
media/

# ─────────────────────────────────────────
# Build / Dist
# ─────────────────────────────────────────
dist/
build/
*.egg-info/
.eggs/